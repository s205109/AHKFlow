{
  "AppSettings": {
    "Environment": "docker"
  },
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "ClientId": "18680edd-0d55-4280-a3a6-d0df5acd6c03",
    "TenantId": "e97883e4-340d-4299-b85b-4e4ded6846cf",
    "CallbackPath": "/signin-oidc",
    "Scopes": "access_as_user"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=sqlserver,1433;Database=AHKFlowDb;User Id=sa;Password=AHKFlow_Dev!2026;TrustServerCertificate=True;MultipleActiveResultSets=true",
