{
  "AzureAd": {
    "ClientId": "YOUR_CLIENT_ID",
    "Authority": "https://login.microsoftonline.com/YOUR_TENANT_ID",
    "ValidateAuthority": true
  },
  "ApiHttpClient": {
    "BaseAddress": "YOUR_API_BASE_ADDRESS",
    "BaseAddressCandidates": [
      "YOUR_API_BASE_ADDRESS_LOCALDB",
      "YOUR_API_BASE_ADDRESS_DOCKER_COMPOSE",
      "YOUR_API_BASE_ADDRESS_DOCKER_API_ONLY"
    ]
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.BrowserConsole" ],
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning",
        "AHKFlow": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "BrowserConsole",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ],
    "Properties": {
      "ApplicationName": "AHKFlow.UI.Blazor"
    }
  }
}
