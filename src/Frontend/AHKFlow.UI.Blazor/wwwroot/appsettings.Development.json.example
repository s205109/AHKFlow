{
    // Copy this file to appsettings.Development.json and fill in your values
    // appsettings.Development.json is gitignored
    "AzureAd": {
        "ClientId": "YOUR_CLIENT_ID",
        "Authority": "https://login.microsoftonline.com/YOUR_TENANT_ID",
        "ValidateAuthority": true
    },
    "ApiHttpClient": {
        // BaseAddress is the preferred API endpoint (tried first)
        "BaseAddress": "https://localhost:7600",
        // BaseAddressCandidates are fallbacks if BaseAddress is unreachable
        // These correspond to launchSettings.json profiles:
        // - https://localhost:7600 (LocalDB HTTPS)
        // - http://localhost:5600  (LocalDB HTTP)
        // - http://localhost:5602  (Docker Compose)
        // - http://localhost:5604  (Docker API only)
        "BaseAddressCandidates": [
            "https://localhost:7600",
            "http://localhost:5600",
            "http://localhost:5602",
            "http://localhost:5604"
        ]
    },
    "Serilog": {
        "MinimumLevel": {
            "Default": "Information",
            "Override": {
                "AHKFlow": "Debug"
            }
        }
    }
}
